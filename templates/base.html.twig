<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}Fichajes{% endblock %}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    {% block stylesheets %}{% endblock %}
</head>
<body class="bg-body-tertiary">
<nav class="navbar navbar-expand-lg bg-dark navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="{{ path('app_dashboard') }}">Fichajes V1</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navPrincipal">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navPrincipal">
            {% if app.user %}
                {% set rutaActual = app.request.attributes.get('_route') %}
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    <li class="nav-item"><a class="nav-link {{ rutaActual starts with 'web_herramienta_fichaje_kiosko' ? 'active' : '' }}" href="{{ path('web_herramienta_fichaje_kiosko') }}">Kiosko fichaje</a></li>
                    <li class="nav-item"><a class="nav-link {{ rutaActual starts with 'web_fichajes_' ? 'active' : '' }}" href="{{ path('web_fichajes_index') }}">Fichajes</a></li>
                    <li class="nav-item"><a class="nav-link {{ rutaActual starts with 'web_horarios_' ? 'active' : '' }}" href="{{ path('web_horarios_index') }}">Horarios</a></li>
                    <li class="nav-item"><a class="nav-link {{ rutaActual starts with 'web_ausencias_' ? 'active' : '' }}" href="{{ path('web_ausencias_index') }}">Ausencias</a></li>
                    <li class="nav-item"><a class="nav-link {{ rutaActual starts with 'web_trabajadores_' ? 'active' : '' }}" href="{{ path('web_trabajadores_index') }}">Trabajadores</a></li>
                    <li class="nav-item"><a class="nav-link {{ rutaActual starts with 'web_correcciones_' ? 'active' : '' }}" href="{{ path('web_correcciones_index') }}">Correcciones</a></li>
                    <li class="nav-item"><a class="nav-link {{ rutaActual starts with 'web_auditoria_' ? 'active' : '' }}" href="{{ path('web_auditoria_index') }}">Auditoría</a></li>
                </ul>
            {% endif %}
            <div class="d-flex align-items-center gap-2 text-white">
                {% if app.user %}
                    <span class="badge text-bg-info">Tenant {{ app.user.tenantId }}</span>
                    <span>{{ app.user.userIdentifier }}</span>
                    <a class="btn btn-sm btn-outline-light" href="{{ path('app_logout') }}">Salir</a>
                {% else %}
                    <a class="btn btn-sm btn-outline-light" href="{{ path('app_login') }}">Entrar</a>
                {% endif %}
            </div>
        </div>
    </div>
</nav>

<div class="position-fixed top-0 end-0 p-3" style="z-index: 1080; max-width: 420px;">
    {% for tipo, mensajes in app.flashes %}
        {% for mensaje in mensajes %}
            <div class="alert alert-{{ tipo == 'error' ? 'danger' : tipo }} alert-dismissible fade show shadow" role="alert">
                {{ mensaje }}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        {% endfor %}
    {% endfor %}
</div>

<main class="container py-4">

    {% block body %}{% endblock %}
</main>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
{% block javascripts %}{% endblock %}
</body>
</html>
