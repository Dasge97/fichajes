{% extends 'base.html.twig' %}

{% block title %}Ausencias{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="h4 mb-0">Ausencias</h1>
        <a class="btn btn-primary" href="{{ path('web_ausencias_nueva') }}">Añadir ausencia</a>
    </div>

    <section class="card mb-4"><div class="card-body">
    <h2 class="h6 mb-3">Buscar solicitudes</h2>
    <form method="get" class="row g-2 mb-0">
        <div class="col-md-4"><input class="form-control" name="empleadoId" value="{{ filtroEmpleado }}" placeholder="Filtrar por empleado"></div>
        <div class="col-md-3">
            <select class="form-select" name="estado">
                <option value="" {{ filtros.estado == '' ? 'selected' : '' }}>Todos los estados</option>
                <option value="pendiente" {{ filtros.estado == 'pendiente' ? 'selected' : '' }}>Pendiente</option>
                <option value="aprobada" {{ filtros.estado == 'aprobada' ? 'selected' : '' }}>Aprobada</option>
                <option value="rechazada" {{ filtros.estado == 'rechazada' ? 'selected' : '' }}>Rechazada</option>
            </select>
        </div>
        <div class="col-md-2">
            {% include 'web/_tamano_select.html.twig' with {nombre: 'tamano', valor: filtros.tamano} %}
        </div>
        <input type="hidden" name="pagina" value="1">
        <div class="col-md-3 d-flex gap-2"><button class="btn btn-outline-secondary w-100">Filtrar</button><a class="btn btn-outline-secondary" href="{{ path('web_ausencias_index') }}">Limpiar</a></div>
    </form>
    </div></section>

    <section>
    <h2 class="h6 mb-2">Solicitudes registradas</h2>
    <table class="table table-striped align-middle">
        <thead><tr><th>Empleado</th><th>Tipo</th><th>Periodo</th><th>Estado</th><th class="text-end">Acciones</th></tr></thead>
        <tbody>
        {% for item in items %}
            <tr>
                <td>{{ item.empleadoId }}</td>
                <td>{{ item.tipo }}</td>
                <td>{{ item.fechaInicio }} - {{ item.fechaFin }}</td>
                <td><span class="badge text-bg-{{ item.estado == 'aprobada' ? 'success' : (item.estado == 'rechazada' ? 'danger' : 'secondary') }}">{{ item.estado }}</span></td>
                <td class="text-end" style="white-space: nowrap; width: 1%;">
                    {% if is_granted('ROLE_SUPERVISOR') and item.estado == 'pendiente' %}
                        <form method="post" action="{{ path('web_ausencias_aprobar', {id: item.id}) }}" class="d-inline">
                            <input type="hidden" name="_token" value="{{ csrf_token('ausencia_aprobar_' ~ item.id) }}"><button class="btn btn-sm btn-outline-success">Aprobar</button>
                        </form>
                        <form method="post" action="{{ path('web_ausencias_rechazar', {id: item.id}) }}" class="d-inline">
                            <input type="hidden" name="_token" value="{{ csrf_token('ausencia_rechazar_' ~ item.id) }}"><button class="btn btn-sm btn-outline-danger">Rechazar</button>
                        </form>
                    {% else %}
                        <span class="text-muted">-</span>
                    {% endif %}
                </td>
            </tr>
        {% else %}
            <tr><td colspan="5" class="text-muted">Sin solicitudes.</td></tr>
        {% endfor %}
        </tbody>
    </table>
    {% include 'web/_paginacion.html.twig' with {ruta: 'web_ausencias_index', query: {empleadoId: filtroEmpleado, estado: filtros.estado, tamano: filtros.tamano}, paginacion: paginacion} %}
    </section>
{% endblock %}
