{% extends 'base.html.twig' %}

{% block title %}Solicitar ausencia — Fichajes{% endblock %}

{% block body %}
<div class="mb-6">
    <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider flex items-center gap-1 mb-0.5">
        <a href="{{ path('app_dashboard') }}" class="hover:text-gray-600 transition-colors">Inicio</a>
        <i class="ti ti-chevron-right text-gray-300" style="font-size:.65rem;"></i>
        <a href="{{ path('web_ausencias_index') }}" class="hover:text-gray-600 transition-colors">Ausencias</a>
        <i class="ti ti-chevron-right text-gray-300" style="font-size:.65rem;"></i>
        <span>Nueva solicitud</span>
    </p>
    <div class="flex items-center gap-3">
        <a href="{{ path('web_ausencias_index') }}"
           class="inline-flex items-center gap-1 rounded-lg border border-gray-300 px-3 py-1.5 text-xs font-medium text-gray-600 hover:bg-gray-50 transition-colors">
            <i class="ti ti-arrow-left"></i>Volver
        </a>
        <h1 class="text-2xl font-bold text-gray-900">Solicitar ausencia</h1>
    </div>
</div>

<div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6">
    <form method="post" action="{{ path('web_ausencias_solicitar') }}" class="flex flex-wrap items-end gap-4">
        <input type="hidden" name="_token" value="{{ csrf_token('ausencia_solicitar') }}">
        <div class="flex-1 min-w-44">
            <label class="block text-sm font-medium text-gray-700 mb-1.5">Trabajador</label>
            <select class="w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm focus:border-blue-500 focus:ring-1 focus:ring-blue-500 outline-none transition" name="trabajadorId" required>
                <option value="">Selecciona trabajador…</option>
                {% for trabajador in trabajadores %}
                    <option value="{{ trabajador.trabajadorId }}">{{ trabajador.trabajadorId }} — {{ trabajador.nombre }}</option>
                {% endfor %}
            </select>
        </div>
        <div class="min-w-44">
            <label class="block text-sm font-medium text-gray-700 mb-1.5">Tipo de ausencia</label>
            <input class="w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm focus:border-blue-500 focus:ring-1 focus:ring-blue-500 outline-none transition"
                   name="tipo" placeholder="vacaciones / permiso / baja" required>
        </div>
        <div class="min-w-36">
            <label class="block text-sm font-medium text-gray-700 mb-1.5">Fecha inicio</label>
            <input class="w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm focus:border-blue-500 focus:ring-1 focus:ring-blue-500 outline-none transition"
                   type="date" name="fechaInicio" required>
        </div>
        <div class="min-w-36">
            <label class="block text-sm font-medium text-gray-700 mb-1.5">Fecha fin</label>
            <input class="w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm focus:border-blue-500 focus:ring-1 focus:ring-blue-500 outline-none transition"
                   type="date" name="fechaFin" required>
        </div>
        <button class="inline-flex items-center gap-1.5 rounded-lg bg-blue-600 px-5 py-2.5 text-sm font-semibold text-white hover:bg-blue-700 transition-colors">
            <i class="ti ti-device-floppy"></i>Guardar
        </button>
    </form>
</div>
{% endblock %}
