{% extends 'base.html.twig' %}

{% block title %}Fichajes — Fichajes{% endblock %}

{% block body %}
<div class="page-header d-print-none pt-3 pb-2">
    <div class="row align-items-center">
        <div class="col">
            <div class="page-pretitle text-secondary">Registro</div>
            <h2 class="page-title"><i class="ti ti-clock me-2"></i>Fichajes</h2>
        </div>
        <div class="col-auto ms-auto">
            <a class="btn btn-primary" href="{{ path('web_fichajes_nuevo') }}">
                <i class="ti ti-plus me-1"></i>Añadir fichaje
            </a>
        </div>
    </div>
</div>

<div class="card mb-3">
    <div class="card-header">
        <h3 class="card-title mb-0"><i class="ti ti-filter me-2 text-secondary"></i>Filtros</h3>
    </div>
    <div class="card-body">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-8">
                <input class="form-control" name="q" value="{{ filtros.q }}"
                       placeholder="Buscar por empleado, tipo o estado">
            </div>
            <div class="col-md-2">
                {% include 'web/_tamano_select.html.twig' with {nombre: 'tamano', valor: filtros.tamano} %}
            </div>
            <input type="hidden" name="pagina" value="1">
            <div class="col-md-2 d-flex gap-2">
                <button class="btn btn-primary w-100"><i class="ti ti-search me-1"></i>Filtrar</button>
                <a class="btn btn-outline-secondary" href="{{ path('web_fichajes_index') }}"><i class="ti ti-x"></i></a>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-header">
        <h3 class="card-title mb-0">Historial reciente</h3>
    </div>
    <div class="table-responsive">
        <table class="table table-vcenter card-table">
            <thead>
                <tr>
                    <th>Empleado</th>
                    <th>Tipo</th>
                    <th>Fecha y hora</th>
                    <th>Estado</th>
                    <th>Motivo desvío</th>
                </tr>
            </thead>
            <tbody>
            {% for item in eventos %}
                <tr>
                    <td class="fw-medium">{{ item.empleadoId }}</td>
                    <td>
                        {% set tipoIcono = {
                            'clock-in': 'ti-login',
                            'clock-out': 'ti-logout',
                            'pause-start': 'ti-player-pause',
                            'pause-end': 'ti-player-play'
                        } %}
                        <span class="d-flex align-items-center gap-1">
                            <i class="ti {{ tipoIcono[item.tipo] ?? 'ti-clock' }} text-secondary"></i>
                            {{ item.tipo }}
                        </span>
                    </td>
                    <td class="text-secondary">{{ item.ocurridoEn }}</td>
                    <td>
                        <span class="badge {{ item.estadoCumplimiento == 'dentro_horario' ? 'bg-success-lt text-success' : 'bg-warning-lt text-warning' }}">
                            {{ item.estadoCumplimiento }}
                        </span>
                    </td>
                    <td class="text-secondary">{{ item.motivoDesvio ?: '—' }}</td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="5" class="text-center text-secondary py-4">
                        <i class="ti ti-clock-off fs-2 d-block mb-2"></i>Sin eventos registrados.
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
    <div class="card-footer d-flex justify-content-end">
        {% include 'web/_paginacion.html.twig' with {ruta: 'web_fichajes_index', query: {q: filtros.q, tamano: filtros.tamano}, paginacion: paginacion} %}
    </div>
</div>
{% endblock %}
