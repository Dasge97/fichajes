{% extends 'base.html.twig' %}

{% block title %}Registrar fichaje — Fichajes{% endblock %}

{% block body %}
<div class="page-header d-print-none pt-3 pb-2">
    <div class="row align-items-center">
        <div class="col-auto">
            <a class="btn btn-outline-secondary btn-sm" href="{{ path('web_fichajes_index') }}">
                <i class="ti ti-arrow-left me-1"></i>Volver
            </a>
        </div>
        <div class="col">
            <div class="page-pretitle text-secondary">Fichajes</div>
            <h2 class="page-title">Registrar fichaje</h2>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <form method="post" action="{{ path('web_fichajes_registrar') }}" class="row g-3 align-items-end">
            <input type="hidden" name="_token" value="{{ csrf_token('fichaje_registrar') }}">

            <div class="col-md-4">
                <label class="form-label">Trabajador</label>
                <select class="form-select" name="trabajadorId" required>
                    <option value="">Selecciona trabajador…</option>
                    {% for trabajador in trabajadores %}
                        <option value="{{ trabajador.trabajadorId }}">
                            {{ trabajador.trabajadorId }} — {{ trabajador.nombre }}
                        </option>
                    {% endfor %}
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label">Tipo de evento</label>
                <select class="form-select" name="tipo" required>
                    <option value="clock-in">Entrada</option>
                    <option value="pause-start">Inicio pausa</option>
                    <option value="pause-end">Fin pausa</option>
                    <option value="clock-out">Salida</option>
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label">Fecha y hora</label>
                <input class="form-control" type="datetime-local" name="ocurridoEn" required>
            </div>
            <div class="col-md-2">
                <button class="btn btn-primary w-100">
                    <i class="ti ti-device-floppy me-1"></i>Guardar
                </button>
            </div>
        </form>
    </div>
</div>
{% endblock %}
