{% extends 'base.html.twig' %}

{% block title %}{{ trabajador.nombre }} — Trabajadores{% endblock %}

{% block body %}
<div class="mb-6">
    <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider flex items-center gap-1 mb-0.5">
        <a href="{{ path('app_dashboard') }}" class="hover:text-gray-600 transition-colors">Inicio</a>
        <i class="ti ti-chevron-right text-gray-300" style="font-size:.65rem;"></i>
        <a href="{{ path('web_trabajadores_index', filtros) }}" class="hover:text-gray-600 transition-colors">Trabajadores</a>
        <i class="ti ti-chevron-right text-gray-300" style="font-size:.65rem;"></i>
        <span>{{ trabajador.nombre }}</span>
    </p>
    <div class="flex items-center gap-3">
        <a href="{{ path('web_trabajadores_index', filtros) }}"
           class="inline-flex items-center gap-1 rounded-lg border border-gray-300 px-3 py-1.5 text-xs font-medium text-gray-600 hover:bg-gray-50 transition-colors">
            <i class="ti ti-arrow-left"></i>Volver
        </a>
        <h1 class="text-2xl font-bold text-gray-900 flex items-center gap-2">
            <i class="ti ti-user text-blue-500"></i>{{ trabajador.nombre }}
        </h1>
        {% if is_granted('ROLE_SUPERVISOR') %}
        <a href="{{ path('web_trabajadores_editar_form', {trabajadorId: trabajador.trabajadorId}|merge(filtros)) }}"
           class="inline-flex items-center gap-1.5 rounded-lg bg-blue-600 px-4 py-2 text-sm font-semibold text-white hover:bg-blue-700 transition-colors">
            <i class="ti ti-pencil"></i>Editar
        </a>
        {% endif %}
    </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
    {# Datos del trabajador #}
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6">
        <h3 class="text-sm font-semibold text-gray-900 mb-4 flex items-center gap-2">
            <i class="ti ti-id-badge text-gray-400"></i>Datos del trabajador
        </h3>
        <dl class="space-y-3">
            <div class="flex justify-between gap-4">
                <dt class="text-xs font-medium text-gray-500">ID</dt>
                <dd class="text-sm font-mono text-gray-900">{{ trabajador.trabajadorId }}</dd>
            </div>
            <div class="flex justify-between gap-4">
                <dt class="text-xs font-medium text-gray-500">Nombre</dt>
                <dd class="text-sm font-medium text-gray-900">{{ trabajador.nombre }}</dd>
            </div>
            <div class="flex justify-between gap-4">
                <dt class="text-xs font-medium text-gray-500">Email laboral</dt>
                <dd class="text-sm text-gray-700">{{ trabajador.email ?: '—' }}</dd>
            </div>
            <div class="flex justify-between gap-4">
                <dt class="text-xs font-medium text-gray-500">Fecha de alta</dt>
                <dd class="text-sm text-gray-700">{{ trabajador.fechaAlta|date('d/m/Y') }}</dd>
            </div>
            <div class="flex justify-between gap-4">
                <dt class="text-xs font-medium text-gray-500">Estado</dt>
                <dd>
                    <span class="inline-flex items-center rounded px-2 py-0.5 text-xs font-medium {{ trabajador.estaActivo ? 'bg-green-100 text-green-800' : 'bg-gray-100 text-gray-500' }}">
                        <i class="ti ti-{{ trabajador.estaActivo ? 'circle-check' : 'circle-x' }} mr-1"></i>
                        {{ trabajador.estaActivo ? 'Activo' : 'Inactivo' }}
                    </span>
                </dd>
            </div>
        </dl>
    </div>

    {# Cuenta web #}
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6">
        <h3 class="text-sm font-semibold text-gray-900 mb-4 flex items-center gap-2">
            <i class="ti ti-shield-lock text-gray-400"></i>Cuenta web
        </h3>
        {% if cuenta.tieneCuenta %}
        <dl class="space-y-3">
            <div class="flex justify-between gap-4">
                <dt class="text-xs font-medium text-gray-500">Estado</dt>
                <dd>
                    <span class="inline-flex items-center rounded px-2 py-0.5 text-xs font-medium {{ cuenta.activo ? 'bg-green-100 text-green-800' : 'bg-gray-100 text-gray-500' }}">
                        {{ cuenta.activo ? 'Activa' : 'Bloqueada' }}
                    </span>
                </dd>
            </div>
            <div class="flex justify-between gap-4">
                <dt class="text-xs font-medium text-gray-500">Roles</dt>
                <dd class="flex flex-wrap gap-1 justify-end">
                    {% if cuenta.roles is not empty %}
                        {% for rol in cuenta.roles %}
                            <span class="inline-flex items-center rounded px-2 py-0.5 text-xs font-medium bg-blue-100 text-blue-800">{{ rol }}</span>
                        {% endfor %}
                    {% else %}
                        <span class="text-xs text-gray-400">Sin roles</span>
                    {% endif %}
                </dd>
            </div>
        </dl>
        {% else %}
        <div class="flex items-center gap-2 text-sm text-gray-400">
            <i class="ti ti-user-off text-xl"></i>
            <span>Sin cuenta web</span>
        </div>
        {% endif %}
    </div>
</div>
{% endblock %}
