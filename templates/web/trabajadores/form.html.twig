{% extends 'base.html.twig' %}

{% block title %}{{ modo == 'crear' ? 'Nuevo trabajador' : 'Editar trabajador' }} — Fichajes{% endblock %}

{% block body %}
<div class="mb-6">
    <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider flex items-center gap-1 mb-0.5">
        <a href="{{ path('app_dashboard') }}" class="hover:text-gray-600 transition-colors">Inicio</a>
        <i class="ti ti-chevron-right text-gray-300" style="font-size:.65rem;"></i>
        <a href="{{ path('web_trabajadores_index', filtros) }}" class="hover:text-gray-600 transition-colors">Trabajadores</a>
        <i class="ti ti-chevron-right text-gray-300" style="font-size:.65rem;"></i>
        <span>{{ modo == 'crear' ? 'Nuevo' : 'Editar' }}</span>
    </p>
    <div class="flex items-center gap-3">
        <a href="{{ path('web_trabajadores_index', filtros) }}"
           class="inline-flex items-center gap-1 rounded-lg border border-gray-300 px-3 py-1.5 text-xs font-medium text-gray-600 hover:bg-gray-50 transition-colors">
            <i class="ti ti-arrow-left"></i>Volver
        </a>
        <h1 class="text-2xl font-bold text-gray-900">{{ modo == 'crear' ? 'Nuevo trabajador' : 'Editar trabajador' }}</h1>
    </div>
</div>

<div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6">
    <form method="post"
          action="{{ modo == 'crear' ? path('web_trabajadores_crear') : path('web_trabajadores_editar', {trabajadorId: trabajador.trabajadorId}) }}"
          class="space-y-5">
        <input type="hidden" name="_token" value="{{ csrf_token(modo == 'crear' ? 'trabajador_crear' : 'trabajador_editar_' ~ trabajador.trabajadorId) }}">
        <input type="hidden" name="q" value="{{ filtros.q }}">
        <input type="hidden" name="estado" value="{{ filtros.estado }}">
        <input type="hidden" name="pagina" value="{{ filtros.pagina }}">
        <input type="hidden" name="tamano" value="{{ filtros.tamano }}">

        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-4">
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1.5">ID de trabajador</label>
                <input class="w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm focus:border-blue-500 focus:ring-1 focus:ring-blue-500 outline-none transition {{ modo == 'editar' ? 'bg-gray-50 text-gray-500' : '' }}"
                       name="trabajadorId" value="{{ trabajador ? trabajador.trabajadorId : '' }}" placeholder="TRAB-001"
                       {{ modo == 'editar' ? 'readonly' : '' }} required>
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1.5">Nombre completo</label>
                <input class="w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm focus:border-blue-500 focus:ring-1 focus:ring-blue-500 outline-none transition"
                       name="nombre" value="{{ trabajador ? trabajador.nombre : '' }}" placeholder="Nombre y apellidos" required>
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1.5">Email laboral <span class="text-gray-400 font-normal">(opcional)</span></label>
                <input class="w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm focus:border-blue-500 focus:ring-1 focus:ring-blue-500 outline-none transition"
                       name="email" type="email" value="{{ trabajador ? trabajador.email : '' }}" placeholder="empleado@empresa.com">
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1.5">PIN kiosco</label>
                <input class="w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm focus:border-blue-500 focus:ring-1 focus:ring-blue-500 outline-none transition"
                       name="pinKiosko" type="password" placeholder="••••">
            </div>
        </div>

        {% if modo == 'crear' %}
        <div class="border-t border-gray-100 pt-5">
            <h3 class="text-sm font-semibold text-gray-900 mb-4 flex items-center gap-2">
                <i class="ti ti-shield-lock text-gray-400"></i>Cuenta web
                <span class="text-xs text-gray-400 font-normal">(separada del PIN de kiosco)</span>
            </h3>
            <div class="space-y-4">
                <label class="flex items-center gap-2 cursor-pointer">
                    <input id="crearCuentaWeb" class="w-4 h-4 rounded border-gray-300 text-blue-600 focus:ring-blue-500"
                           type="checkbox" name="crearCuentaWeb" value="1">
                    <span class="text-sm text-gray-700">Crear cuenta web ahora</span>
                </label>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1.5">Email de login web</label>
                        <input class="w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm focus:border-blue-500 focus:ring-1 focus:ring-blue-500 outline-none transition"
                               name="emailCuentaWeb" type="email" placeholder="login@empresa.com">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1.5">Contraseña inicial web</label>
                        <input class="w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm focus:border-blue-500 focus:ring-1 focus:ring-blue-500 outline-none transition"
                               name="passwordCuentaWeb" type="password" minlength="12" placeholder="Mínimo 12 caracteres">
                    </div>
                </div>
            </div>
        </div>
        {% endif %}

        <div class="pt-2">
            <button class="inline-flex items-center gap-1.5 rounded-lg bg-blue-600 px-5 py-2.5 text-sm font-semibold text-white hover:bg-blue-700 transition-colors">
                <i class="ti ti-device-floppy"></i>Guardar
            </button>
        </div>
    </form>
</div>

{% if modo == 'editar' %}

{# Estado del trabajador #}
<div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6 mt-4">
    <h3 class="text-sm font-semibold text-gray-900 mb-4 flex items-center gap-2">
        <i class="ti ti-toggle-right text-gray-400"></i>Estado del trabajador
    </h3>
    <div class="flex items-center gap-4">
        <span class="inline-flex items-center rounded px-2.5 py-1 text-xs font-medium {{ trabajador.estaActivo ? 'bg-green-100 text-green-800' : 'bg-gray-100 text-gray-500' }}">
            <i class="ti ti-{{ trabajador.estaActivo ? 'circle-check' : 'circle-x' }} mr-1"></i>
            {{ trabajador.estaActivo ? 'Activo' : 'Inactivo' }}
        </span>
        <form method="post" action="{{ path('web_trabajadores_estado', {trabajadorId: trabajador.trabajadorId}) }}" class="inline">
            <input type="hidden" name="_token" value="{{ csrf_token('trabajador_estado_' ~ trabajador.trabajadorId) }}">
            <input type="hidden" name="q" value="{{ filtros.q }}">
            <input type="hidden" name="estado" value="{{ filtros.estado }}">
            <input type="hidden" name="pagina" value="{{ filtros.pagina }}">
            <input type="hidden" name="tamano" value="{{ filtros.tamano }}">
            <input type="hidden" name="activo" value="{{ trabajador.estaActivo ? '0' : '1' }}">
            <button class="inline-flex items-center gap-1 rounded-lg border px-3 py-1.5 text-xs font-medium transition-colors {{ trabajador.estaActivo ? 'border-yellow-300 text-yellow-700 hover:bg-yellow-50' : 'border-green-300 text-green-700 hover:bg-green-50' }}">
                <i class="ti ti-{{ trabajador.estaActivo ? 'player-pause' : 'player-play' }}"></i>
                {{ trabajador.estaActivo ? 'Desactivar' : 'Activar' }}
            </button>
        </form>
    </div>
</div>

{% if puedeGestionarCuentas %}
{# Cuenta web #}
<div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6 mt-4">
    <h3 class="text-sm font-semibold text-gray-900 mb-4 flex items-center gap-2">
        <i class="ti ti-shield-lock text-gray-400"></i>Cuenta web
    </h3>

    {% if cuenta.tieneCuenta %}
    <div class="space-y-5">
        {# Estado cuenta #}
        <div class="flex items-center gap-4">
            <span class="inline-flex items-center rounded px-2.5 py-1 text-xs font-medium {{ cuenta.activo ? 'bg-green-100 text-green-800' : 'bg-gray-100 text-gray-500' }}">
                {{ cuenta.activo ? 'Activa' : 'Bloqueada' }}
            </span>
            <form method="post" action="{{ path('web_trabajadores_cuenta_estado', {trabajadorId: trabajador.trabajadorId}) }}" class="inline">
                <input type="hidden" name="_token" value="{{ csrf_token('trabajador_cuenta_estado_' ~ trabajador.trabajadorId) }}">
                <input type="hidden" name="q" value="{{ filtros.q }}">
                <input type="hidden" name="estado" value="{{ filtros.estado }}">
                <input type="hidden" name="pagina" value="{{ filtros.pagina }}">
                <input type="hidden" name="tamano" value="{{ filtros.tamano }}">
                <input type="hidden" name="activo" value="{{ cuenta.activo ? '0' : '1' }}">
                <button class="inline-flex items-center gap-1 rounded-lg border px-3 py-1.5 text-xs font-medium transition-colors {{ cuenta.activo ? 'border-yellow-300 text-yellow-700 hover:bg-yellow-50' : 'border-green-300 text-green-700 hover:bg-green-50' }}">
                    <i class="ti ti-{{ cuenta.activo ? 'lock' : 'lock-open' }}"></i>
                    {{ cuenta.activo ? 'Bloquear web' : 'Activar web' }}
                </button>
            </form>
        </div>

        {# Roles #}
        <div class="border-t border-gray-100 pt-4">
            <p class="text-xs font-medium text-gray-500 mb-2">Roles asignados</p>
            <div class="flex flex-wrap items-center gap-2 mb-3">
                {% if cuenta.roles is not empty %}
                    {% for rol in cuenta.roles %}
                        <span class="inline-flex items-center rounded px-2 py-0.5 text-xs font-medium bg-blue-100 text-blue-800">{{ rol }}</span>
                    {% endfor %}
                {% else %}
                    <span class="text-xs text-gray-400">Sin roles</span>
                {% endif %}
            </div>
            <form method="post" action="{{ path('web_trabajadores_cuenta_rol', {trabajadorId: trabajador.trabajadorId}) }}" class="flex items-center gap-2">
                <input type="hidden" name="_token" value="{{ csrf_token('trabajador_cuenta_rol_' ~ trabajador.trabajadorId) }}">
                <input type="hidden" name="q" value="{{ filtros.q }}">
                <input type="hidden" name="estado" value="{{ filtros.estado }}">
                <input type="hidden" name="pagina" value="{{ filtros.pagina }}">
                <input type="hidden" name="tamano" value="{{ filtros.tamano }}">
                <select class="rounded-lg border border-gray-300 px-3 py-1.5 text-xs focus:border-blue-500 outline-none transition" name="rol">
                    <option value="trabajador">trabajador</option>
                    <option value="responsable_equipo">responsable_equipo</option>
                </select>
                <button name="accionRol" value="asignar" class="inline-flex items-center gap-1 rounded-lg bg-green-600 px-3 py-1.5 text-xs font-semibold text-white hover:bg-green-700 transition-colors">
                    <i class="ti ti-plus"></i>Asignar
                </button>
                <button name="accionRol" value="revocar" class="inline-flex items-center gap-1 rounded-lg border border-yellow-400 px-3 py-1.5 text-xs font-semibold text-yellow-700 hover:bg-yellow-50 transition-colors">
                    <i class="ti ti-minus"></i>Revocar
                </button>
            </form>
        </div>

        {# Reset contraseña #}
        <div class="border-t border-gray-100 pt-4">
            <p class="text-xs font-medium text-gray-500 mb-2">Resetear contraseña web</p>
            <form method="post" action="{{ path('web_trabajadores_cuenta_reset', {trabajadorId: trabajador.trabajadorId}) }}" class="flex flex-wrap items-end gap-2">
                <input type="hidden" name="_token" value="{{ csrf_token('trabajador_cuenta_reset_' ~ trabajador.trabajadorId) }}">
                <input type="hidden" name="q" value="{{ filtros.q }}">
                <input type="hidden" name="estado" value="{{ filtros.estado }}">
                <input type="hidden" name="pagina" value="{{ filtros.pagina }}">
                <input type="hidden" name="tamano" value="{{ filtros.tamano }}">
                <div>
                    <label class="block text-xs text-gray-500 mb-1">Token (vacío = emitir nuevo)</label>
                    <input class="rounded-lg border border-gray-300 px-3 py-1.5 text-xs focus:border-blue-500 outline-none transition w-52"
                           name="token" type="text" placeholder="Token de reset">
                </div>
                <div>
                    <label class="block text-xs text-gray-500 mb-1">Nueva contraseña</label>
                    <input class="rounded-lg border border-gray-300 px-3 py-1.5 text-xs focus:border-blue-500 outline-none transition w-52"
                           name="password" type="password" minlength="12" placeholder="Mínimo 12 caracteres">
                </div>
                <button class="inline-flex items-center gap-1 rounded-lg border border-red-300 px-3 py-1.5 text-xs font-medium text-red-600 hover:bg-red-50 transition-colors">
                    <i class="ti ti-key"></i>Confirmar reset
                </button>
            </form>
        </div>
    </div>

    {% else %}
    {# Crear cuenta #}
    <form method="post" action="{{ path('web_trabajadores_cuenta_crear', {trabajadorId: trabajador.trabajadorId}) }}" class="space-y-4">
        <input type="hidden" name="_token" value="{{ csrf_token('trabajador_cuenta_crear_' ~ trabajador.trabajadorId) }}">
        <input type="hidden" name="q" value="{{ filtros.q }}">
        <input type="hidden" name="estado" value="{{ filtros.estado }}">
        <input type="hidden" name="pagina" value="{{ filtros.pagina }}">
        <input type="hidden" name="tamano" value="{{ filtros.tamano }}">
        <p class="text-xs text-gray-400">Este trabajador no tiene cuenta web. Puedes crearle una para que acceda a la aplicación.</p>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
                <label class="block text-xs font-medium text-gray-500 mb-1">Email de acceso <span class="text-gray-400 font-normal">(opcional, usa el del trabajador si no se indica)</span></label>
                <input class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:border-blue-500 focus:ring-1 focus:ring-blue-500 outline-none transition"
                       name="email" type="email" placeholder="{{ trabajador.email ?: 'email@empresa.com' }}">
            </div>
            <div>
                <label class="block text-xs font-medium text-gray-500 mb-1">Contraseña inicial <span class="text-red-400">*</span></label>
                <input class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:border-blue-500 focus:ring-1 focus:ring-blue-500 outline-none transition"
                       name="password" type="password" minlength="12" placeholder="Mínimo 12 caracteres" required>
            </div>
        </div>
        <button class="inline-flex items-center gap-1.5 rounded-lg border border-green-400 bg-green-50 px-4 py-2 text-sm font-semibold text-green-700 hover:bg-green-100 transition-colors">
            <i class="ti ti-user-plus"></i>Crear cuenta web
        </button>
    </form>
    {% endif %}
</div>
{% endif %}

{% endif %}
{% endblock %}
