{% extends 'base.html.twig' %}

{% block title %}{{ modo == 'crear' ? 'Nuevo trabajador' : 'Editar trabajador' }} — Fichajes{% endblock %}

{% block body %}
<div class="page-header d-print-none pt-3 pb-2">
    <div class="row align-items-center">
        <div class="col-auto">
            <a class="btn btn-outline-secondary btn-sm" href="{{ path('web_trabajadores_index', filtros) }}">
                <i class="ti ti-arrow-left me-1"></i>Volver
            </a>
        </div>
        <div class="col">
            <div class="page-pretitle text-secondary">Trabajadores</div>
            <h2 class="page-title">{{ modo == 'crear' ? 'Nuevo trabajador' : 'Editar trabajador' }}</h2>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <form method="post"
              action="{{ modo == 'crear' ? path('web_trabajadores_crear') : path('web_trabajadores_editar', {trabajadorId: trabajador.trabajadorId}) }}"
              class="row g-3">
            <input type="hidden" name="_token"
                   value="{{ csrf_token(modo == 'crear' ? 'trabajador_crear' : 'trabajador_editar_' ~ trabajador.trabajadorId) }}">
            <input type="hidden" name="q" value="{{ filtros.q }}">
            <input type="hidden" name="estado" value="{{ filtros.estado }}">
            <input type="hidden" name="pagina" value="{{ filtros.pagina }}">
            <input type="hidden" name="tamano" value="{{ filtros.tamano }}">

            <div class="col-md-3">
                <label class="form-label">ID de trabajador</label>
                <input class="form-control" name="trabajadorId"
                       value="{{ trabajador ? trabajador.trabajadorId : '' }}"
                       placeholder="TRAB-001"
                       {{ modo == 'editar' ? 'readonly' : '' }} required>
            </div>
            <div class="col-md-4">
                <label class="form-label">Nombre completo</label>
                <input class="form-control" name="nombre"
                       value="{{ trabajador ? trabajador.nombre : '' }}"
                       placeholder="Nombre y apellidos" required>
            </div>
            <div class="col-md-3">
                <label class="form-label">Email laboral <span class="text-secondary">(opcional)</span></label>
                <input class="form-control" name="email" type="email"
                       value="{{ trabajador ? trabajador.email : '' }}"
                       placeholder="empleado@empresa.com">
            </div>
            <div class="col-md-2">
                <label class="form-label">PIN kiosco</label>
                <input class="form-control" name="pinKiosko" type="password" placeholder="••••">
            </div>

            {% if modo == 'crear' %}
                <div class="col-12">
                    <hr class="my-1">
                    <h3 class="card-title mt-3">
                        <i class="ti ti-shield-lock me-2 text-secondary"></i>Cuenta web
                        <small class="text-secondary fw-normal">(separada del PIN de kiosco)</small>
                    </h3>
                </div>
                <div class="col-12">
                    <label class="form-check">
                        <input class="form-check-input" type="checkbox" id="crearCuentaWeb" name="crearCuentaWeb" value="1">
                        <span class="form-check-label">Crear cuenta web ahora</span>
                    </label>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Email de login web</label>
                    <input class="form-control" name="emailCuentaWeb" type="email" placeholder="login@empresa.com">
                </div>
                <div class="col-md-3">
                    <label class="form-label">Contraseña inicial web</label>
                    <input class="form-control" name="passwordCuentaWeb" type="password" minlength="12" placeholder="Mínimo 12 caracteres">
                </div>
            {% endif %}

            <div class="col-12 pt-2">
                <button class="btn btn-primary" type="submit">
                    <i class="ti ti-device-floppy me-1"></i>Guardar
                </button>
            </div>
        </form>
    </div>
</div>
{% endblock %}
