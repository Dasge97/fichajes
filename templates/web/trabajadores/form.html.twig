{% extends 'base.html.twig' %}

{% block title %}{{ modo == 'crear' ? 'Nuevo trabajador' : 'Editar trabajador' }}{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="h4 mb-0">{{ modo == 'crear' ? 'Nuevo trabajador' : 'Editar trabajador' }}</h1>
        <a class="btn btn-outline-secondary" href="{{ path('web_trabajadores_index', filtros) }}">Volver</a>
    </div>
    <section class="card"><div class="card-body">
        <form method="post" action="{{ modo == 'crear' ? path('web_trabajadores_crear') : path('web_trabajadores_editar', {trabajadorId: trabajador.trabajadorId}) }}" class="row g-2">
            <input type="hidden" name="_token" value="{{ csrf_token(modo == 'crear' ? 'trabajador_crear' : 'trabajador_editar_' ~ trabajador.trabajadorId) }}">
            <input type="hidden" name="q" value="{{ filtros.q }}">
            <input type="hidden" name="estado" value="{{ filtros.estado }}">
            <input type="hidden" name="pagina" value="{{ filtros.pagina }}">
            <input type="hidden" name="tamano" value="{{ filtros.tamano }}">
            <div class="col-md-3"><input class="form-control" name="trabajadorId" value="{{ trabajador ? trabajador.trabajadorId : '' }}" placeholder="TRAB-001" {{ modo == 'editar' ? 'readonly' : '' }} required></div>
            <div class="col-md-4"><input class="form-control" name="nombre" value="{{ trabajador ? trabajador.nombre : '' }}" placeholder="Nombre" required></div>
            <div class="col-md-3"><input class="form-control" name="email" type="email" value="{{ trabajador ? trabajador.email : '' }}" placeholder="Email laboral opcional"></div>
            <div class="col-md-2"><input class="form-control" name="pinKiosko" type="password" placeholder="PIN kiosko"></div>
            {% if modo == 'crear' %}
                <div class="col-12 mt-3"><h2 class="h6">Cuenta web (separada del PIN kiosko)</h2></div>
                <div class="col-md-3 form-check mt-2 ms-2">
                    <input class="form-check-input" type="checkbox" id="crearCuentaWeb" name="crearCuentaWeb" value="1">
                    <label class="form-check-label" for="crearCuentaWeb">Crear cuenta web ahora</label>
                </div>
                <div class="col-md-4"><input class="form-control" name="emailCuentaWeb" type="email" placeholder="Email de login web"></div>
                <div class="col-md-3"><input class="form-control" name="passwordCuentaWeb" type="password" minlength="12" placeholder="Password inicial web"></div>
            {% endif %}
            <div class="col-12"><button class="btn btn-primary">Guardar</button></div>
        </form>
    </div></section>
{% endblock %}
