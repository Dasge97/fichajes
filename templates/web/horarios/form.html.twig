{% extends 'base.html.twig' %}

{% block title %}{{ modo == 'crear' ? 'Nuevo horario' : 'Editar horario' }} — Fichajes{% endblock %}

{% block body %}
<div class="page-header d-print-none pt-3 pb-2">
    <div class="row align-items-center">
        <div class="col-auto">
            <a class="btn btn-outline-secondary btn-sm" href="{{ path('web_horarios_index') }}">
                <i class="ti ti-arrow-left me-1"></i>Volver
            </a>
        </div>
        <div class="col">
            <div class="page-pretitle text-secondary">Horarios</div>
            <h2 class="page-title">{{ modo == 'crear' ? 'Nuevo horario' : 'Editar horario' }}</h2>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <form method="post"
              action="{{ modo == 'crear' ? path('web_horarios_crear') : path('web_horarios_editar', {id: horario.id}) }}"
              class="row g-3">
            <input type="hidden" name="_token"
                   value="{{ csrf_token(modo == 'crear' ? 'horario_crear' : 'horario_editar_' ~ horario.id) }}">

            <div class="col-md-4">
                <label class="form-label">Nombre del horario</label>
                <input class="form-control" name="nombre"
                       value="{{ horario ? horario.nombre : '' }}"
                       placeholder="Ej. Turno mañana L-V" required>
            </div>
            <div class="col-md-8">
                <label class="form-label">
                    Tramos
                    <span class="text-secondary ms-1 small">(una línea por tramo: día, HH:MM, HH:MM)</span>
                </label>
                <textarea class="form-control font-monospace" name="tramos" rows="5"
                          placeholder="lunes, 09:00, 17:00&#10;martes, 09:00, 17:00&#10;..." required>{% if horario %}{{ horario.tramos|replace({'[':'',']':'','{':'','}':'','"':'','dia:':'','inicio:':'','fin:':''}) }}{% endif %}</textarea>
            </div>
            <div class="col-12 pt-2">
                <button class="btn btn-primary" type="submit">
                    <i class="ti ti-device-floppy me-1"></i>Guardar
                </button>
            </div>
        </form>
    </div>
</div>
{% endblock %}
