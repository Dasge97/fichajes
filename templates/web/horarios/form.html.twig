{% extends 'base.html.twig' %}

{% block title %}{{ modo == 'crear' ? 'Nuevo horario' : 'Editar horario' }}{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="h4 mb-0">{{ modo == 'crear' ? 'Nuevo horario' : 'Editar horario' }}</h1>
        <a class="btn btn-outline-secondary" href="{{ path('web_horarios_index') }}">Volver</a>
    </div>
    <section class="card"><div class="card-body">
        <form method="post" action="{{ modo == 'crear' ? path('web_horarios_crear') : path('web_horarios_editar', {id: horario.id}) }}" class="row g-2">
            <input type="hidden" name="_token" value="{{ csrf_token(modo == 'crear' ? 'horario_crear' : 'horario_editar_' ~ horario.id) }}">
            <div class="col-md-4"><input class="form-control" name="nombre" value="{{ horario ? horario.nombre : '' }}" placeholder="Nombre" required></div>
            <div class="col-md-8"><textarea class="form-control" name="tramos" rows="4" placeholder="dia,inicio,fin (una linea por tramo)" required>{% if horario %}{{ horario.tramos|replace({'[':'',']':'','{':'','}':'','"':'','dia:':'','inicio:':'','fin:':''}) }}{% endif %}</textarea></div>
            <div class="col-12"><button class="btn btn-primary">Guardar</button></div>
        </form>
    </div></section>
{% endblock %}
