{% extends 'base.html.twig' %}

{% block title %}Horarios — Fichajes{% endblock %}

{% block body %}
<div class="page-header d-print-none pt-3 pb-2">
    <div class="row align-items-center">
        <div class="col">
            <div class="page-pretitle text-secondary">Gestión</div>
            <h2 class="page-title"><i class="ti ti-calendar-event me-2"></i>Horarios</h2>
        </div>
        {% if is_granted('ROLE_SUPERVISOR') %}
            <div class="col-auto ms-auto d-flex gap-2">
                <a class="btn btn-primary" href="{{ path('web_horarios_nuevo') }}">
                    <i class="ti ti-plus me-1"></i>Añadir horario
                </a>
                <a class="btn btn-outline-primary" href="{{ path('web_horarios_asignacion_nueva') }}">
                    <i class="ti ti-user-check me-1"></i>Asignar horario
                </a>
            </div>
        {% endif %}
    </div>
</div>

<div class="card mb-3">
    <div class="card-header">
        <h3 class="card-title mb-0"><i class="ti ti-filter me-2 text-secondary"></i>Filtros de horarios</h3>
    </div>
    <div class="card-body">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-8">
                <input class="form-control" name="q" value="{{ filtros.q }}" placeholder="Buscar por ID o nombre">
            </div>
            <div class="col-md-2">
                {% include 'web/_tamano_select.html.twig' with {nombre: 'tamano', valor: filtros.tamano} %}
            </div>
            <input type="hidden" name="pagina" value="1">
            <input type="hidden" name="qAsig" value="{{ filtrosAsig.qAsig }}">
            <input type="hidden" name="tamanoAsig" value="{{ filtrosAsig.tamanoAsig }}">
            <input type="hidden" name="paginaAsig" value="{{ paginacionAsig.paginaAsig }}">
            <div class="col-md-2 d-flex gap-2">
                <button class="btn btn-primary w-100"><i class="ti ti-search me-1"></i>Filtrar</button>
                <a class="btn btn-outline-secondary" href="{{ path('web_horarios_index') }}"><i class="ti ti-x"></i></a>
            </div>
        </form>
    </div>
</div>

<div class="card mb-4">
    <div class="card-header">
        <h3 class="card-title mb-0">Catálogo de horarios</h3>
    </div>
    <div class="table-responsive">
        <table class="table table-vcenter card-table">
            <thead>
                <tr>
                    <th style="width:120px;">ID</th>
                    <th>Nombre</th>
                    <th>Tramos</th>
                    <th class="text-end" style="width:100px;">Acciones</th>
                </tr>
            </thead>
            <tbody>
            {% for h in horarios %}
                <tr>
                    <td><code class="text-muted">{{ h.id }}</code></td>
                    <td class="fw-medium">{{ h.nombre }}</td>
                    <td><code class="text-secondary small">{{ h.tramos|slice(0, 80) }}{% if h.tramos|length > 80 %}…{% endif %}</code></td>
                    <td class="text-end">
                        {% if is_granted('ROLE_SUPERVISOR') %}
                            <a class="btn btn-sm btn-outline-primary" href="{{ path('web_horarios_editar_form', {id: h.id}) }}">
                                <i class="ti ti-pencil me-1"></i>Editar
                            </a>
                        {% else %}
                            <span class="text-secondary small">Solo supervisor</span>
                        {% endif %}
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="4" class="text-center text-secondary py-4">
                        <i class="ti ti-calendar-off fs-2 d-block mb-2"></i>No hay horarios.
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
    <div class="card-footer d-flex justify-content-end">
        {% include 'web/_paginacion.html.twig' with {
            ruta: 'web_horarios_index',
            query: {q: filtros.q, tamano: filtros.tamano, qAsig: filtrosAsig.qAsig, tamanoAsig: filtrosAsig.tamanoAsig, paginaAsig: paginacionAsig.paginaAsig},
            paginacion: {pagina: paginacion.pagina, totalPaginas: paginacion.totalPaginas}
        } %}
    </div>
</div>

<div class="card">
    <div class="card-header">
        <h3 class="card-title mb-0"><i class="ti ti-user-check me-2 text-secondary"></i>Asignaciones recientes</h3>
    </div>
    <div class="card-body border-bottom">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-8">
                <input class="form-control" name="qAsig" value="{{ filtrosAsig.qAsig }}" placeholder="Buscar por empleado u horario">
            </div>
            <div class="col-md-2">
                {% include 'web/_tamano_select.html.twig' with {nombre: 'tamanoAsig', valor: filtrosAsig.tamanoAsig} %}
            </div>
            <input type="hidden" name="paginaAsig" value="1">
            <input type="hidden" name="q" value="{{ filtros.q }}">
            <input type="hidden" name="tamano" value="{{ filtros.tamano }}">
            <input type="hidden" name="pagina" value="{{ paginacion.pagina }}">
            <div class="col-md-2 d-flex gap-2">
                <button class="btn btn-primary w-100"><i class="ti ti-search me-1"></i>Filtrar</button>
                <a class="btn btn-outline-secondary" href="{{ path('web_horarios_index') }}"><i class="ti ti-x"></i></a>
            </div>
        </form>
    </div>
    <div class="table-responsive">
        <table class="table table-vcenter card-table">
            <thead>
                <tr>
                    <th>Empleado</th>
                    <th>Horario</th>
                    <th>Vigente desde</th>
                    <th>Vigente hasta</th>
                </tr>
            </thead>
            <tbody>
            {% for a in asignaciones %}
                <tr>
                    <td class="fw-medium">{{ a.empleadoId }}</td>
                    <td><code class="text-muted">{{ a.horarioId }}</code></td>
                    <td class="text-secondary">{{ a.vigenteDesde }}</td>
                    <td class="text-secondary">{{ a.vigenteHasta ?: '<span class="badge bg-success-lt text-success">Indefinido</span>'|raw }}</td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="4" class="text-center text-secondary py-4">
                        <i class="ti ti-user-off fs-2 d-block mb-2"></i>Sin asignaciones.
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
    <div class="card-footer d-flex justify-content-end">
        {% include 'web/_paginacion.html.twig' with {
            ruta: 'web_horarios_index',
            query: {qAsig: filtrosAsig.qAsig, tamanoAsig: filtrosAsig.tamanoAsig, q: filtros.q, tamano: filtros.tamano, pagina: paginacion.pagina},
            paginacion: {pagina: paginacionAsig.paginaAsig, totalPaginas: paginacionAsig.totalPaginasAsig}
        } %}
    </div>
</div>
{% endblock %}
