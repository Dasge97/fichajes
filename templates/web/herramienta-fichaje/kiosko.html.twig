{% extends 'base.html.twig' %}

{% block title %}Kiosko fichaje{% endblock %}

{% block body %}
    <section class="card border-0 shadow-sm">
        <div class="card-body p-3 p-md-4">
            <h1 class="h4 mb-3">Kiosko de fichaje</h1>

            <div class="row g-3">
                <div class="col-lg-4">
                    <section class="card h-100">
                        <div class="card-body">
                            <h2 class="h6 mb-2">Fichar por codigo</h2>
                            <p class="text-muted small mb-3">Introduce tu codigo y elige accion.</p>

                            <input type="hidden" id="csrfValidarPin" value="{{ csrf_token('herramienta_fichaje_kiosko_validar_pin') }}">
                            <input type="hidden" id="csrfRapida" value="{{ csrf_token('herramienta_fichaje_kiosko_rapida') }}">

                            <label class="form-label">Codigo</label>
                            <input class="form-control form-control-lg text-center" id="inputCodigo" autocomplete="off" inputmode="none" required>

                            <div class="row g-2 mt-2">
                                {% for fila in [[1,2,3],[4,5,6],[7,8,9],['C',0,'⌫']] %}
                                    {% for tecla in fila %}
                                        <div class="col-4 d-grid">
                                            {% if tecla is same as('C') %}
                                                <button type="button" class="btn btn-outline-secondary btn-lg py-3 tecla-kiosko" data-op="clear">C</button>
                                            {% elseif tecla is same as('⌫') %}
                                                <button type="button" class="btn btn-outline-secondary btn-lg py-3 tecla-kiosko" data-op="back">⌫</button>
                                            {% else %}
                                                <button type="button" class="btn btn-outline-primary btn-lg py-3 tecla-kiosko" data-numero="{{ tecla }}">{{ tecla }}</button>
                                            {% endif %}
                                        </div>
                                    {% endfor %}
                                {% endfor %}
                            </div>
                            <button type="button" class="btn btn-primary btn-lg w-100 mt-3" id="btnValidarPin">Validar codigo</button>
                        </div>
                    </section>
                </div>

                <div class="col-lg-8">
                    <section class="card h-100">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center gap-2 mb-3">
                                <h2 class="h6 mb-0">Trabajadores del tenant</h2>
                                <form method="get" class="d-flex gap-2">
                                    <input class="form-control form-control-sm" name="q" value="{{ q }}" placeholder="Buscar trabajador">
                                    <button class="btn btn-sm btn-outline-secondary">Buscar</button>
                                </form>
                            </div>

                            <div class="table-responsive">
                                <table class="table table-sm align-middle">
                                    <thead><tr><th>Trabajador</th><th>Estado</th><th>Acciones</th></tr></thead>
                                    <tbody>
                                    {% for fila in trabajadoresKiosko %}
                                        <tr>
                                            <td><strong>{{ fila.trabajador.trabajadorId }}</strong> - {{ fila.trabajador.nombre }}</td>
                                            <td><span class="badge text-bg-secondary">{{ fila.estado|replace({'_': ' '}) }}</span></td>
                                            <td>
                                                <div class="d-flex flex-wrap gap-1">
                                                    {% for accion in fila.acciones %}
                                                        {% set etiqueta = accion == 'iniciar_nuevo' ? 'Iniciar jornada' : (accion == 'pausa' ? 'Pausar' : (accion == 'reanudar' ? 'Reanudar' : 'Finalizar')) %}
                                                        {% set clase = accion == 'iniciar_nuevo' ? 'btn-primary' : (accion == 'pausa' ? 'btn-warning' : (accion == 'reanudar' ? 'btn-success' : 'btn-danger')) %}
                                                        <button type="button" class="btn btn-sm {{ clase }} btn-accion-rapida"
                                                                data-trabajador-id="{{ fila.trabajador.trabajadorId }}"
                                                                data-trabajador-nombre="{{ fila.trabajador.nombre }}"
                                                                data-accion="{{ accion }}"
                                                                data-etiqueta="{{ etiqueta }}"
                                                                data-bs-toggle="modal"
                                                                data-bs-target="#modalAccionRapida">{{ etiqueta }}</button>
                                                    {% endfor %}
                                                </div>
                                            </td>
                                        </tr>
                                    {% else %}
                                        <tr><td colspan="3" class="text-muted">No hay trabajadores para mostrar.</td></tr>
                                    {% endfor %}
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </section>
                </div>
            </div>
        </div>
    </section>

    <div class="modal fade" id="modalAccionRapida" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <form method="post" action="{{ path('web_herramienta_fichaje_kiosko_rapida') }}">
                    <div class="modal-header"><h5 class="modal-title">Confirmar accion</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
                    <div class="modal-body">
                        <input type="hidden" name="_token" id="modalTokenRapida" value="{{ csrf_token('herramienta_fichaje_kiosko_rapida') }}">
                        <input type="hidden" name="trabajadorId" id="modalTrabajadorId">
                        <input type="hidden" name="accion" id="modalAccion">
                        <p class="mb-2">Trabajador: <strong id="modalTrabajadorNombre"></strong></p>
                        <p class="mb-3">Accion: <strong id="modalAccionEtiqueta"></strong></p>
                        <label class="form-label">Codigo de fichaje</label>
                        <input class="form-control" type="password" name="claveAcceso" autocomplete="off" required>
                    </div>
                    <div class="modal-footer"><button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button><button class="btn btn-primary">Confirmar</button></div>
                </form>
            </div>
        </div>
    </div>

    <div class="modal fade" id="modalAccionPin" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <form method="post" action="{{ path('web_herramienta_fichaje_kiosko_rapida') }}" id="formAccionPin">
                    <div class="modal-header"><h5 class="modal-title">Selecciona accion</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
                    <div class="modal-body">
                        <input type="hidden" name="_token" value="{{ csrf_token('herramienta_fichaje_kiosko_rapida') }}">
                        <input type="hidden" name="trabajadorId" id="pinTrabajadorId">
                        <input type="hidden" name="claveAcceso" id="pinCodigoEnviado">
                        <input type="hidden" name="accion" id="pinAccionElegida">
                        <p class="mb-2">Trabajador: <strong id="pinTrabajadorNombre"></strong></p>
                        <div class="d-flex flex-wrap gap-2" id="pinAcciones"></div>
                    </div>
                </form>
            </div>
        </div>
    </div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        (function(){
            const inputCodigo = document.getElementById('inputCodigo');
            const esMovil = /Android|iPhone|iPad|iPod/i.test(navigator.userAgent);
            if (inputCodigo && esMovil) {
                inputCodigo.setAttribute('readonly', 'readonly');
                inputCodigo.addEventListener('focus', () => inputCodigo.blur());
            }
            document.querySelectorAll('.tecla-kiosko').forEach(btn => {
                btn.addEventListener('click', () => {
                    const op = btn.dataset.op;
                    if (op === 'clear') inputCodigo.value = '';
                    else if (op === 'back') inputCodigo.value = inputCodigo.value.slice(0, -1);
                    else if (btn.dataset.numero) inputCodigo.value += btn.dataset.numero;
                });
            });

            const modalRapida = document.getElementById('modalAccionRapida');
            if (modalRapida) {
                modalRapida.addEventListener('show.bs.modal', event => {
                    const b = event.relatedTarget; if (!b) return;
                    document.getElementById('modalTrabajadorId').value = b.dataset.trabajadorId || '';
                    document.getElementById('modalAccion').value = b.dataset.accion || '';
                    document.getElementById('modalTrabajadorNombre').textContent = `${b.dataset.trabajadorId || ''} - ${b.dataset.trabajadorNombre || ''}`;
                    document.getElementById('modalAccionEtiqueta').textContent = b.dataset.etiqueta || '';
                });
            }

            const btnValidar = document.getElementById('btnValidarPin');
            if (btnValidar) {
                btnValidar.addEventListener('click', async () => {
                    const codigo = (inputCodigo?.value || '').trim();
                    if (!codigo) return;
                    const data = new URLSearchParams();
                    data.set('_token', document.getElementById('csrfValidarPin').value);
                    data.set('claveAcceso', codigo);
                    const resp = await fetch('{{ path('web_herramienta_fichaje_kiosko_validar_pin') }}', {
                        method: 'POST',
                        headers: {'Content-Type': 'application/x-www-form-urlencoded'},
                        body: data.toString()
                    });
                    const json = await resp.json().catch(() => ({ok:false,mensaje:'Error de validacion'}));
                    if (!json.ok) {
                        window.location.reload();
                        return;
                    }
                    const accionesCont = document.getElementById('pinAcciones');
                    accionesCont.innerHTML = '';
                    document.getElementById('pinTrabajadorId').value = json.trabajadorId;
                    document.getElementById('pinTrabajadorNombre').textContent = `${json.trabajadorId} - ${json.trabajadorNombre}`;
                    document.getElementById('pinCodigoEnviado').value = codigo;
                    json.acciones.forEach(acc => {
                        const btn = document.createElement('button');
                        btn.type = 'button';
                        btn.className = 'btn ' + (acc === 'iniciar_nuevo' ? 'btn-primary' : (acc === 'pausa' ? 'btn-warning' : (acc === 'reanudar' ? 'btn-success' : 'btn-danger')));
                        btn.textContent = acc === 'iniciar_nuevo' ? 'Iniciar jornada' : (acc === 'pausa' ? 'Pausar' : (acc === 'reanudar' ? 'Reanudar' : 'Finalizar'));
                        btn.addEventListener('click', () => {
                            document.getElementById('pinAccionElegida').value = acc;
                            document.getElementById('formAccionPin').submit();
                        });
                        accionesCont.appendChild(btn);
                    });
                    new bootstrap.Modal(document.getElementById('modalAccionPin')).show();
                });
            }
        })();
    </script>
{% endblock %}
