{% extends 'base.html.twig' %}

{% block title %}Auditoría{% endblock %}

{% block body %}
<div class="mb-6">
    <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider flex items-center gap-1 mb-0.5">
        <a href="{{ path('app_dashboard') }}" class="hover:text-gray-600 transition-colors">Inicio</a>
        <i class="ti ti-chevron-right text-gray-300" style="font-size:.65rem;"></i>
        <span>Auditoría</span>
    </p>
    <h1 class="text-2xl font-bold text-gray-900 flex items-center gap-2">
        <i class="ti ti-list-search text-blue-500"></i>Auditoría
    </h1>
</div>

<div class="bg-white rounded-xl border border-gray-200 shadow-sm mb-4">
    <div class="px-5 py-4 border-b border-gray-100">
        <h3 class="text-sm font-semibold text-gray-700 flex items-center gap-2"><i class="ti ti-filter text-gray-400"></i>Filtros</h3>
    </div>
    <div class="p-5">
        <form method="get" class="flex flex-wrap items-end gap-3">
            <div class="flex-1 min-w-48">
                <label class="block text-xs font-medium text-gray-500 mb-1">Acción</label>
                <input class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm font-mono focus:border-blue-500 focus:ring-1 focus:ring-blue-500 outline-none transition"
                       name="accion" value="{{ filtros.accion }}" placeholder="fichaje.registrado, ausencia.aprobada…">
            </div>
            <div class="min-w-32">
                <label class="block text-xs font-medium text-gray-500 mb-1">Desde</label>
                <input class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:border-blue-500 focus:ring-1 focus:ring-blue-500 outline-none transition"
                       type="date" name="desde" value="{{ filtros.desde }}">
            </div>
            <div class="min-w-32">
                <label class="block text-xs font-medium text-gray-500 mb-1">Hasta</label>
                <input class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:border-blue-500 focus:ring-1 focus:ring-blue-500 outline-none transition"
                       type="date" name="hasta" value="{{ filtros.hasta }}">
            </div>
            {% include 'web/_tamano_select.html.twig' with {nombre: 'tamano', valor: filtros.tamano} %}
            <input type="hidden" name="pagina" value="1">
            <button class="inline-flex items-center gap-1.5 rounded-lg bg-blue-600 px-4 py-2 text-sm font-semibold text-white hover:bg-blue-700 transition-colors">
                <i class="ti ti-search"></i>Filtrar
            </button>
            <a href="{{ path('web_auditoria_index') }}"
               class="inline-flex items-center gap-1 rounded-lg border border-gray-300 px-3 py-2 text-sm text-gray-600 hover:bg-gray-50 transition-colors">
                <i class="ti ti-x"></i>Limpiar
            </a>
        </form>
    </div>
</div>

<div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
    <div class="px-5 py-4 border-b border-gray-100">
        <h3 class="text-sm font-semibold text-gray-900">Registros de auditoría</h3>
    </div>
    <div class="overflow-x-auto">
        <table class="w-full text-sm">
            <thead class="bg-gray-50 border-b border-gray-200">
                <tr>
                    <th class="px-5 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider w-40">Fecha</th>
                    <th class="px-5 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Acción</th>
                    <th class="px-5 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Estado anterior</th>
                    <th class="px-5 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Estado posterior</th>
                </tr>
            </thead>
            {% set etiquetas = {
                'fichaje.registrado':       'Fichaje registrado',
                'ausencia.solicitada':      'Ausencia solicitada',
                'ausencia.aprobada':        'Ausencia aprobada',
                'ausencia.rechazada':       'Ausencia rechazada',
                'ausencia.cancelada':       'Ausencia cancelada',
                'correccion.solicitada':    'Corrección solicitada',
                'correccion.aprobada':      'Corrección aprobada',
                'horario.creado':           'Horario creado',
                'horario.editado':          'Horario editado',
                'asignacion.creada':        'Asignación creada',
                'trabajador.creado':        'Trabajador creado',
                'trabajador.editado':       'Trabajador editado',
                'usuario.login':            'Inicio de sesión',
                'usuario.clave_cambiada':   'Clave cambiada'
            } %}
            <tbody class="divide-y divide-gray-100">
            {% for item in items %}
                <tr class="hover:bg-gray-50 transition-colors">
                    <td class="px-5 py-3 text-xs text-gray-400 font-mono">{{ item.creadoEn|date('d/m/Y H:i') }}</td>
                    <td class="px-5 py-3">
                        <p class="text-sm font-medium text-gray-800">{{ etiquetas[item.accion] ?? item.accion }}</p>
                        <p class="text-xs text-gray-400 font-mono mt-0.5">{{ item.accion }}</p>
                    </td>
                    <td class="px-5 py-3">
                        {% if item.antes %}
                            <dl class="text-xs space-y-0.5">
                                {% for k, v in item.antes %}
                                    <div><span class="text-gray-400">{{ k }}:</span> <span class="text-gray-600 font-medium">{{ v }}</span></div>
                                {% endfor %}
                            </dl>
                        {% else %}
                            <span class="text-gray-300">—</span>
                        {% endif %}
                    </td>
                    <td class="px-5 py-3">
                        {% if item.despues %}
                            <dl class="text-xs space-y-0.5">
                                {% for k, v in item.despues %}
                                    <div><span class="text-gray-400">{{ k }}:</span> <span class="text-gray-600 font-medium">{{ v }}</span></div>
                                {% endfor %}
                            </dl>
                        {% else %}
                            <span class="text-gray-300">—</span>
                        {% endif %}
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="4" class="px-5 py-12 text-center text-gray-400">
                        <i class="ti ti-notes-off text-3xl block mb-2"></i>Sin registros de auditoría.
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
    <div class="px-5 py-3 border-t border-gray-100 flex justify-end">
        {% include 'web/_paginacion.html.twig' with {ruta: 'web_auditoria_index', query: {accion: filtros.accion, desde: filtros.desde, hasta: filtros.hasta, tamano: filtros.tamano}, paginacion: paginacion} %}
    </div>
</div>
{% endblock %}
