{% extends 'base.html.twig' %}

{% block title %}Auditoría{% endblock %}

{% block body %}
    <h1 class="h4 mb-3">Auditoría</h1>

    <section class="card mb-4"><div class="card-body">
    <h2 class="h6 mb-3">Filtros</h2>
    <form method="get" class="row g-2 mb-0">
        <div class="col-md-4"><input class="form-control" name="accion" value="{{ filtros.accion }}" placeholder="Acción"></div>
        <div class="col-md-2"><input class="form-control" type="date" name="desde" value="{{ filtros.desde }}"></div>
        <div class="col-md-2"><input class="form-control" type="date" name="hasta" value="{{ filtros.hasta }}"></div>
        <div class="col-md-2">
            {% include 'web/_tamano_select.html.twig' with {nombre: 'tamano', valor: filtros.tamano} %}
        </div>
        <input type="hidden" name="pagina" value="1">
        <div class="col-md-2 d-flex gap-2"><button class="btn btn-outline-secondary w-100">Filtrar</button><a class="btn btn-outline-secondary" href="{{ path('web_auditoria_index') }}">Limpiar</a></div>
    </form>
    </div></section>

    <section>
    <h2 class="h6 mb-2">Registros de auditoria</h2>
    <table class="table table-striped align-middle">
        <thead><tr><th>Fecha</th><th>Acción</th><th>Antes</th><th>Después</th></tr></thead>
        <tbody>
        {% for item in items %}
            <tr>
                <td>{{ item.creadoEn }}</td>
                <td><span class="badge text-bg-dark">{{ item.accion }}</span></td>
                <td><code>{{ item.antes ?: '-' }}</code></td>
                <td><code>{{ item.despues ?: '-' }}</code></td>
            </tr>
        {% else %}
            <tr><td colspan="4" class="text-muted">Sin registros.</td></tr>
        {% endfor %}
        </tbody>
    </table>
    {% include 'web/_paginacion.html.twig' with {ruta: 'web_auditoria_index', query: {accion: filtros.accion, desde: filtros.desde, hasta: filtros.hasta, tamano: filtros.tamano}, paginacion: paginacion} %}
    </section>
{% endblock %}
