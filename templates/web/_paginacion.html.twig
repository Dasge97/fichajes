<nav aria-label="Paginación" class="mt-3">
    <ul class="pagination pagination-sm mb-0">
        <li class="page-item {{ paginacion.pagina <= 1 ? 'disabled' : '' }}">
            <a class="page-link" href="{{ path(ruta, query|merge({pagina: paginacion.pagina - 1})) }}">
                <i class="ti ti-chevron-left"></i>
            </a>
        </li>
        <li class="page-item disabled">
            <span class="page-link text-secondary">{{ paginacion.pagina }} / {{ paginacion.totalPaginas }}</span>
        </li>
        <li class="page-item {{ paginacion.pagina >= paginacion.totalPaginas ? 'disabled' : '' }}">
            <a class="page-link" href="{{ path(ruta, query|merge({pagina: paginacion.pagina + 1})) }}">
                <i class="ti ti-chevron-right"></i>
            </a>
        </li>
    </ul>
</nav>
