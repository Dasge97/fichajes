{% extends 'base.html.twig' %}

{% block title %}Solicitar corrección — Fichajes{% endblock %}

{% block body %}
<div class="page-header d-print-none pt-3 pb-2">
    <div class="row align-items-center">
        <div class="col-auto">
            <a class="btn btn-outline-secondary btn-sm" href="{{ path('web_correcciones_index') }}">
                <i class="ti ti-arrow-left me-1"></i>Volver
            </a>
        </div>
        <div class="col">
            <div class="page-pretitle text-secondary">Correcciones</div>
            <h2 class="page-title">Solicitar corrección de fichaje</h2>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <form method="post" action="{{ path('web_correcciones_crear') }}" class="row g-3 align-items-end">
            <input type="hidden" name="_token" value="{{ csrf_token('correccion_crear') }}">

            <div class="col-md-3">
                <label class="form-label">ID del evento a corregir</label>
                <input class="form-control font-monospace" name="eventoFichajeId"
                       placeholder="uuid del evento" required>
            </div>
            <div class="col-md-4">
                <label class="form-label">Motivo de la corrección</label>
                <input class="form-control" name="motivo"
                       placeholder="Describe el motivo" required>
            </div>
            <div class="col-md-3">
                <label class="form-label">Fecha y hora corregida <span class="text-secondary">(opcional)</span></label>
                <input class="form-control" type="datetime-local" name="ocurridoEnCorregido">
            </div>
            <div class="col-md-2">
                <button class="btn btn-primary w-100">
                    <i class="ti ti-device-floppy me-1"></i>Guardar
                </button>
            </div>
        </form>
    </div>
</div>
{% endblock %}
