{% extends 'base.html.twig' %}

{% block title %}Correcciones — Fichajes{% endblock %}

{% block body %}
<div class="page-header d-print-none pt-3 pb-2">
    <div class="row align-items-center">
        <div class="col">
            <div class="page-pretitle text-secondary">Gestión</div>
            <h2 class="page-title"><i class="ti ti-pencil me-2"></i>Correcciones</h2>
        </div>
        <div class="col-auto ms-auto">
            <a class="btn btn-primary" href="{{ path('web_correcciones_nueva') }}">
                <i class="ti ti-plus me-1"></i>Añadir corrección
            </a>
        </div>
    </div>
</div>

<div class="card mb-3">
    <div class="card-header">
        <h3 class="card-title mb-0"><i class="ti ti-filter me-2 text-secondary"></i>Filtros</h3>
    </div>
    <div class="card-body">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-5">
                <input class="form-control" name="q" value="{{ filtros.q }}"
                       placeholder="Buscar por evento o motivo">
            </div>
            <div class="col-md-3">
                <select class="form-select" name="estado">
                    <option value="" {{ filtros.estado == '' ? 'selected' : '' }}>Todos los estados</option>
                    <option value="pendiente" {{ filtros.estado == 'pendiente' ? 'selected' : '' }}>Pendiente</option>
                    <option value="aprobada" {{ filtros.estado == 'aprobada' ? 'selected' : '' }}>Aprobada</option>
                </select>
            </div>
            <div class="col-md-2">
                {% include 'web/_tamano_select.html.twig' with {nombre: 'tamano', valor: filtros.tamano} %}
            </div>
            <input type="hidden" name="pagina" value="1">
            <div class="col-md-2 d-flex gap-2">
                <button class="btn btn-primary w-100"><i class="ti ti-search me-1"></i>Filtrar</button>
                <a class="btn btn-outline-secondary" href="{{ path('web_correcciones_index') }}"><i class="ti ti-x"></i></a>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-header">
        <h3 class="card-title mb-0">Solicitudes de corrección</h3>
    </div>
    <div class="table-responsive">
        <table class="table table-vcenter card-table">
            <thead>
                <tr>
                    <th>Evento fichaje</th>
                    <th>Estado</th>
                    <th>Motivo</th>
                    <th>Fecha corregida</th>
                    <th class="text-end">Acciones</th>
                </tr>
            </thead>
            <tbody>
            {% for item in items %}
                <tr>
                    <td><code class="text-muted">{{ item.eventoFichajeId }}</code></td>
                    <td>
                        {% if item.estado == 'aprobada' %}
                            <span class="badge bg-success-lt text-success"><i class="ti ti-circle-check me-1"></i>Aprobada</span>
                        {% else %}
                            <span class="badge bg-warning-lt text-warning"><i class="ti ti-clock me-1"></i>Pendiente</span>
                        {% endif %}
                    </td>
                    <td class="text-secondary">{{ item.motivo }}</td>
                    <td class="text-secondary">{{ item.ocurridoEnCorregido ?: '—' }}</td>
                    <td class="text-end">
                        {% if is_granted('ROLE_SUPERVISOR') and item.estado == 'pendiente' %}
                            <form method="post" action="{{ path('web_correcciones_resolver', {id: item.id}) }}">
                                <input type="hidden" name="_token" value="{{ csrf_token('correccion_resolver_' ~ item.id) }}">
                                <button class="btn btn-sm btn-success">
                                    <i class="ti ti-check me-1"></i>Resolver
                                </button>
                            </form>
                        {% else %}
                            <span class="text-secondary">—</span>
                        {% endif %}
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="5" class="text-center text-secondary py-4">
                        <i class="ti ti-pencil-off fs-2 d-block mb-2"></i>Sin correcciones pendientes.
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
    <div class="card-footer d-flex justify-content-end">
        {% include 'web/_paginacion.html.twig' with {ruta: 'web_correcciones_index', query: {q: filtros.q, estado: filtros.estado, tamano: filtros.tamano}, paginacion: paginacion} %}
    </div>
</div>
{% endblock %}
