{% extends 'base.html.twig' %}

{% block title %}Mi perfil — Fichajes{% endblock %}

{% block body %}
<div class="mb-6">
    <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider flex items-center gap-1 mb-0.5">
        <a href="{{ path('app_dashboard') }}" class="hover:text-gray-600 transition-colors">Inicio</a>
        <i class="ti ti-chevron-right text-gray-300" style="font-size:.65rem;"></i>
        <span>Mi perfil</span>
    </p>
    <h1 class="text-2xl font-bold text-gray-900 flex items-center gap-2">
        <i class="ti ti-user-circle text-blue-500"></i>Mi perfil
    </h1>
</div>

<div class="grid grid-cols-1 md:grid-cols-2 gap-5 mb-5">
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm">
        <div class="px-5 py-4 border-b border-gray-100">
            <h3 class="text-sm font-semibold text-gray-700 flex items-center gap-2">
                <i class="ti ti-mail text-gray-400"></i>Actualizar email de acceso
            </h3>
        </div>
        <div class="p-5">
            <form method="post" action="{{ path('app_perfil_email') }}" class="space-y-4">
                <input type="hidden" name="_token" value="{{ csrf_token('perfil_email') }}">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1.5">Email</label>
                    <input class="w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm focus:border-blue-500 focus:ring-1 focus:ring-blue-500 outline-none transition"
                           type="email" name="email" value="{{ app.user.userIdentifier }}" required>
                </div>
                <button class="inline-flex items-center gap-1.5 rounded-lg bg-blue-600 px-4 py-2 text-sm font-semibold text-white hover:bg-blue-700 transition-colors">
                    <i class="ti ti-device-floppy"></i>Guardar email
                </button>
            </form>
        </div>
    </div>

    <div class="bg-white rounded-xl border border-gray-200 shadow-sm">
        <div class="px-5 py-4 border-b border-gray-100">
            <h3 class="text-sm font-semibold text-gray-700 flex items-center gap-2">
                <i class="ti ti-lock text-gray-400"></i>Cambiar contraseña
            </h3>
        </div>
        <div class="p-5">
            <form method="post" action="{{ path('app_perfil_password') }}" class="space-y-4">
                <input type="hidden" name="_token" value="{{ csrf_token('perfil_password') }}">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1.5">Contraseña actual</label>
                    <input class="w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm focus:border-blue-500 focus:ring-1 focus:ring-blue-500 outline-none transition"
                           type="password" name="password_actual" required>
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1.5">
                        Nueva contraseña <span class="text-gray-400 font-normal">(mín. 12 caracteres)</span>
                    </label>
                    <input class="w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm focus:border-blue-500 focus:ring-1 focus:ring-blue-500 outline-none transition"
                           type="password" name="password_nuevo" minlength="12" required>
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1.5">Confirmar nueva contraseña</label>
                    <input class="w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm focus:border-blue-500 focus:ring-1 focus:ring-blue-500 outline-none transition"
                           type="password" name="password_confirmar" required>
                </div>
                <button class="inline-flex items-center gap-1.5 rounded-lg bg-blue-600 px-4 py-2 text-sm font-semibold text-white hover:bg-blue-700 transition-colors">
                    <i class="ti ti-lock"></i>Cambiar contraseña
                </button>
            </form>
        </div>
    </div>
</div>

<div class="bg-white rounded-xl border border-gray-200 shadow-sm">
    <div class="px-5 py-4 border-b border-gray-100">
        <h3 class="text-sm font-semibold text-gray-700 flex items-center gap-2">
            <i class="ti ti-info-circle text-gray-400"></i>Información de sesión
        </h3>
    </div>
    <div class="p-5">
        <dl class="grid grid-cols-1 sm:grid-cols-3 gap-4 text-sm">
            <div>
                <dt class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">Usuario</dt>
                <dd class="text-gray-900 font-medium">{{ app.user.userIdentifier }}</dd>
            </div>
            <div>
                <dt class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">Tenant</dt>
                <dd class="font-mono text-xs text-blue-600 bg-blue-50 rounded px-2 py-1 inline-block">{{ app.user.tenantId }}</dd>
            </div>
            <div>
                <dt class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">Roles</dt>
                <dd class="flex flex-wrap gap-1">
                    {% for rol in app.user.roles %}
                        <span class="inline-flex items-center rounded px-2 py-0.5 text-xs font-medium bg-blue-100 text-blue-800">{{ rol }}</span>
                    {% endfor %}
                </dd>
            </div>
        </dl>
    </div>
</div>
{% endblock %}
