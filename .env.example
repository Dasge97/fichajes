# Copia este archivo como .env y rellena los valores reales.
# NUNCA subas .env con secretos reales al repositorio.

# Entorno de ejecucion: dev | test | prod
APP_ENV=dev

# Clave secreta de Symfony (CSRF, cookies, cifrado). Genera una con:
#   php -r "echo bin2hex(random_bytes(16));"
APP_SECRET=CAMBIA_ESTE_SECRETO

# Conexion a la base de datos
# SQLite (desarrollo rapido):
DATABASE_URL="sqlite:///%kernel.project_dir%/var/data.db"
# PostgreSQL (produccion recomendada):
# DATABASE_URL="postgresql://usuario:contraseña@localhost:5432/fichajes"

# Administrador inicial (creado con: php bin/console app:bootstrap-admin)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=CAMBIA_ESTE_PASSWORD

# Herramienta de fichaje / kiosco
# Numero maximo de intentos fallidos antes de bloqueo
HERRAMIENTA_FICHAJE_LIMITE_INTENTOS=5
# Ventana de tiempo para contar intentos (segundos)
HERRAMIENTA_FICHAJE_VENTANA_SEGUNDOS=900
# Duracion del bloqueo tras superar el limite (segundos)
HERRAMIENTA_FICHAJE_BLOQUEO_SEGUNDOS=900
# Timeout de inactividad de sesion de kiosco (segundos)
HERRAMIENTA_FICHAJE_TIMEOUT_INACTIVIDAD_SEGUNDOS=120
# Identificador de tenant por defecto para el kiosco
HERRAMIENTA_FICHAJE_TENANT_KIOSKO=T1

# Proxies de confianza (separados por coma). Usa "private_ranges" detras de un reverse proxy local.
TRUSTED_PROXIES=private_ranges
